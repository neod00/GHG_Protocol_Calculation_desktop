{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "GHG Desktop",
    "version":  "0.1.0",
    "identifier":  "com.openbrain.ghgdesktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://127.0.0.1:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "GHG Desktop",
                                    "width":  1280,
                                    "height":  820,
                                    "minWidth":  1100,
                                    "minHeight":  720
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "msi"
                               ],
                   "icon":  [
                                "icons/icon.ico"
                            ]
               },
    "plugins":  {
                    "updater":  {
                                    "endpoints":  [
                                                      "https://ghg-protocol-calculation-desktop-li.vercel.app/api/updates/latest"
                                                  ],
                                    "pubkey":  "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
                                }
                }
}